# OpenAI (para generacion de guiones y voces TTS)
OPENAI_API_KEY=

# Google Gemini / AI Studio (para generacion de imagenes con Imagen 3)
GEMINI_API_KEY=

# Google Vertex AI (alternativa a AI Studio para Imagen 3)
GOOGLE_PROJECT_ID=
GOOGLE_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/ruta/al/service-account.json

# Google TTS (texto a voz)
GOOGLE_TTS_KEY=

# Telegram (notificaciones)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# FFmpeg (ruta al ejecutable)
FFMPEG_PATH=C:\ffmpeg\ffmpeg\bin\ffmpeg.exe

# Servidor
PORT=3000
